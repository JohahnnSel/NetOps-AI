# Copia este archivo a .env y completa los valores reales.
# .env NO debe subirse al repositorio (ver .gitignore).

# API key gratuita de Google AI Studio: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Clave usada por Flask para firmar la cookie de sesión (sid). Genera una
# propia en producción, por ejemplo con: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=dev-secret-change-me

# Ruta del archivo SQLite donde se persisten conversaciones y tool calls.
NETOPS_DB_PATH=data/netops.db

# Puerto en el que escucha el servidor Flask.
PORT=5000

# true/false — nunca lo dejes en true en producción (expone el debugger de Werkzeug).
FLASK_DEBUG=false
